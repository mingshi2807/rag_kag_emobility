{
  "openapi": "3.0.3",
  "info": {
    "title": "RAG/KAG OCPP 2.1",
    "version": "0.3.0"
  },
  "paths": {
    "/ingest": {
      "post": {
        "tags": [
          "ingest"
        ],
        "summary": "Legacy admin document ingestion",
        "description": "Legacy mutation endpoint for direct PDF/JSON ingestion. Requires API_ADMIN_TOKEN bearer auth. Prefer the source-aware corpus CLI flow for OCPP 2.1 Ed2 PDF, Device Model, and JSON schema ingestion.",
        "operationId": "ingest_document_ingest_post",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "parameters": [
          {
            "name": "doc_type",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "spec",
              "title": "Doc Type"
            }
          },
          {
            "name": "protocol",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "ocpp21",
              "title": "Protocol"
            }
          },
          {
            "name": "version",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "2.1",
              "title": "Version"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_ingest_document_ingest_post"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IngestResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
